# Several dependencies (the @gingerwizard/react-daterange-picker fork and the
# react-calendar/react-fit ecosystem it pulls in) still declare React 18 peer
# ranges even though they run fine on the React 19 that Next 15 bundles.
# legacy-peer-deps lets the install resolve like npm v6 instead of erroring on
# those stale peer ranges. Revisit once those packages publish React 19 peers.
legacy-peer-deps=true
